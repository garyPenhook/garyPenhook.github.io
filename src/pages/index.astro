---
import ProjectCard from "../components/ProjectCard.astro";
import BaseLayout from "../layouts/BaseLayout.astro";
import { avrProjects } from "../data/projects";
---

<BaseLayout>
  <main class="page">
    <section class="hero">
      <p class="eyebrow">garyPenhook.github.io</p>
      <h1>Practical tooling for embedded and low-level development.</h1>
      <p class="lead">
        I build focused software for real workflows, with an emphasis on
        Microchip AVR development, editor integration, and maintainable tooling.
      </p>
      <div class="hero-actions">
        <a class="button button-primary" href="https://github.com/garyPenhook">
          View GitHub
        </a>
        <a class="button button-secondary" href="#microchip-avr-projects">
          Explore AVR Projects
        </a>
      </div>
    </section>

    <section class="section" id="microchip-avr-projects">
      <div class="section-heading">
        <p class="eyebrow">Selected Work</p>
        <h2>Microchip AVR Projects</h2>
        <p>
          A focused set of projects around AVR assembly workflows, device packs,
          and developer productivity.
        </p>
      </div>

      <div class="project-gallery">
        {avrProjects.map((project) => <ProjectCard project={project} />)}

        <article class="project-card project-card-placeholder">
          <p class="project-kicker">More Projects</p>
          <h3>Additional AVR work can be added here</h3>
          <p class="project-summary">
            This Astro setup is now structured for multiple project cards, so
            new Microchip AVR projects can be added as separate entries without
            rewriting the page layout.
          </p>
        </article>
      </div>
    </section>
  </main>
</BaseLayout>
