---
import type { Project } from "../data/projects";

type Props = {
  project: Project;
};

const { project } = Astro.props;
---

<article class="project-card">
  <div class="project-header">
    <div>
      <p class="project-kicker">{project.category}</p>
      <h3>{project.title}</h3>
    </div>
    <p class="project-version">{project.version}</p>
  </div>

  <p class="project-summary">{project.summary}</p>

  <div class="tag-row">
    {project.tags.map((tag) => <span class="tag">{tag}</span>)}
  </div>

  <div class="project-grid">
    <section class="detail-panel">
      <h4>Highlights</h4>
      <ul>
        {project.highlights.map((item) => <li>{item}</li>)}
      </ul>
    </section>

    <section class="detail-panel">
      <h4>Development Focus</h4>
      <ul>
        {project.focus.map((item) => <li>{item}</li>)}
      </ul>
    </section>
  </div>

  <div class="project-actions">
    <a class="button button-primary" href={project.repositoryUrl}>Repository</a>
    <a class="button button-secondary" href={project.releasesUrl}>Releases</a>
  </div>
</article>
